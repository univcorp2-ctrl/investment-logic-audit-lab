# investment-logic-audit-lab - 環境変数設定例
# このファイルを .env にコピーして必要な値を設定してください。
# .env は .gitignore に追加して Git にコミットしないこと。

# ============================================================
# 実行モード
# ============================================================

# DRY_RUN=1 に設定するとデータダウンロードや取引計算をスキップして動作確認できる
# 本番実行前に必ず DRY_RUN=1 でテストすること
DRY_RUN=1

# ============================================================
# ロギング
# ============================================================

# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ログファイルパス (空白の場合は標準エラーのみ)
# LOG_FILE=logs/audit.log

# ============================================================
# データソース
# ============================================================

# GitHub API トークン (github_repos.py で使用)
# スコープ: public_repo のみで十分
GITHUB_TOKEN=

# SEC EDGAR API - User-Agent ヘッダー (必須: あなたのメールアドレスを入力)
# 参照: https://www.sec.gov/developer
SEC_USER_AGENT=your-email@example.com

# ============================================================
# バックテスト設定 (CLI デフォルト値の上書き)
# ============================================================

# 片道コスト (basis points)
COST_BPS=5

# スリッページ (basis points)
SLIPPAGE_BPS=2

# グロスエクスポージャー上限 (1.0 = 100%)
MAX_GROSS=1.0
